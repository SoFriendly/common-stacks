# Copy to .env.local and fill in values. Never commit .env.local.

# Tauri updater signing key (generated via `bunx tauri signer generate`).
# Either set PATH to a file or PRIVATE_KEY to the raw key contents.
TAURI_SIGNING_PRIVATE_KEY_PATH=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Apple codesigning + notarization (macOS distribution).
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_CERTIFICATE_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Cloudflare R2 (release artifact hosting).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=commonstacks-releases
