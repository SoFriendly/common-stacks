<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.common_stacks.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/common_stacks_accent</item>
        <item name="android:navigationBarColor">@color/common_stacks_paper</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/common_stacks_paper</item>
    </style>

    <style name="Theme.common_stacks" parent="Theme.common_stacks.Base">
        <item name="android:windowBackground">@drawable/splash_screen</item>
    </style>
</resources>
