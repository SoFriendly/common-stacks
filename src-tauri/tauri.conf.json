{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Common Stacks",
  "mainBinaryName": "CommonStacks",
  "version": "0.1.1",
  "identifier": "com.sofriendly.commonstacks",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Common Stacks",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.commonstacks.com/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5QURFODgxNUVBRjE1QkEKUldTNkZhOWVnZWl0eVRWYVdBaitYTk5welRNSnZFTDdHTzRBMGtLU2R5UzRocEl6dGJPSWtzR3gK"
    }
  }
}
